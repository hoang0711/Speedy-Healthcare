# This port is used for vite server with 'npm start' or 'npm run dev'
# Configured in the file vite.config.js
VITE_PORT=3111


# This port is used in reactServer.cjs to host '/dist' build folder
REACT_SERVER_PORT=10995


# This is the URL that points to the 'server/server.js'
# This is where the SQL server code receives and sends CRUD operations
VITE_API_URL='https://web.engr.oregonstate.edu:8500/api/'